@page
@model MentalHealthSystem_Onos_J.Pages.IndexModel
@{
    ViewData["Title"] = "Records Overview";
    Layout = "_Layout";
}

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               class="form-control"
               placeholder="Search clients, counselors..." />

        <button class="btn btn-primary" type="submit">
            Search
        </button>

        <a asp-page="/ReadPage/Index" class="btn btn-secondary">
            Reset
        </a>
    </div>
</form>

<div class="mb-4">
    <a asp-page="/CreatePage/Index" class="btn btn-primary shadow-sm px-4 fw-bold">
        + Create New Record
    </a>
</div>


<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h1 class="h3 fw-bold text-primary mb-0">Mental Health Counseling Tracker</h1>
            <p class="text-muted small mb-0">System Records Overview</p>
        </div>
    </div>

    <ul class="nav nav-pills mb-4 bg-light p-2 rounded" id="recordTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active fw-bold" id="clients-tab" data-bs-toggle="pill" data-bs-target="#panel-clients" type="button">Clients</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold" id="counselors-tab" data-bs-toggle="pill" data-bs-target="#panel-counselors" type="button">Counselors</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold" id="sessions-tab" data-bs-toggle="pill" data-bs-target="#panel-sessions" type="button">Sessions</button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="panel-clients" role="tabpanel">
            <div class="table-responsive border rounded bg-white">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light small text-uppercase fw-bold text-muted">
                        <tr>
                            <th class="ps-3">ID</th>
                            <th>Name</th>
                            <th>Middle Name</th>
                            <th>Contact Info</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.ClientList)
                        {
                            <tr>
                                <td class="ps-3 text-muted">@c.ClientID</td>
                                <td class="fw-bold">@c.FirstName @c.LastName</td>
                                <td>@c.MiddleName</td>
                                <td><span class="badge bg-light text-dark border fw-normal">@c.ContactInfo</span></td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-page="/UpdatePage/Index"
                                               asp-route-Target="Client"
                                               asp-route-Id="@c.ClientID"
                                               class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>

                                        <a asp-page="/DeletePage/Index"
                                               asp-route-Target="Client"
                                               asp-route-Id="@c.ClientID"
                                               class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-2 small text-muted">Showing @Model.ClientList.Count client record(s)</div>
        </div>

        <div class="tab-pane fade" id="panel-counselors" role="tabpanel">
            <div class="table-responsive border rounded bg-white">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light small text-uppercase fw-bold text-muted">
                        <tr>
                            <th class="ps-3">ID</th>
                            <th>Counselor Name</th>
                            <th>Specialty</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var co in Model.CounselorList)
                        {
                            <tr>
                                <td class="ps-3 text-muted">@co.CounselorID.ToString("D7")</td>
                                <td class="fw-bold">@co.FirstName @co.LastName</td>
                                <td><span class="text-primary fw-medium">@co.Specialty</span></td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-page="/UpdatePage/Index"
                                               asp-route-Target="Counselor"
                                               asp-route-Id="@co.CounselorID"
                                               class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>

                                        <a asp-page="/DeletePage/Index"
                                               asp-route-Target="Counselor"
                                               asp-route-Id="@co.CounselorID"
                                               class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-2 small text-muted">Showing @Model.CounselorList.Count counselor record(s)</div>
        </div>

        <div class="tab-pane fade" id="panel-sessions" role="tabpanel">
            <div class="table-responsive border rounded bg-white">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light small text-uppercase fw-bold text-muted">
                        <tr>
                            <th class="ps-3">SID</th>
                            <th>Date & Time</th>
                            <th>Client</th>
                            <th>Counselor</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.SessionList)
                        {
                            <tr>
                                <td class="ps-3"><code class="fw-bold text-dark">@s.SessionID.ToString()</code></td>
                                <td>
                                    <div class="fw-bold">@s.SessionDate.ToString("MMM dd, yyyy")</div>
                                    <div class="small text-muted">@s.SessionDate.ToString("hh:mm tt")</div>
                                </td>
                                <td>@s.ClientFullName</td>
                                <td>@s.CounselorFullName</td>
                                <td class="text-end">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-page="/UpdatePage/Index"
                                               asp-route-Target="Session"
                                               asp-route-Id="@s.SessionID"
                                               class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>

                                        <a asp-page="/DeletePage/Index"
                                               asp-route-Target="Session"
                                               asp-route-Id="@s.SessionID"
                                               class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-2 small text-muted">Showing @Model.SessionList.Count session record(s)</div>
        </div>
    </div>
</div>