@page
@model MentalHealthSystem_Onos_J.CreatePage.IndexModel
@{
    ViewData["Title"] = "System Records";
    Layout = "_Layout";
}

<!-- SEARCH -->
<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text"
               name="SearchTerm"
               value="@Model.SearchTerm"
               class="form-control"
               placeholder="Search clients, counselors..." />

        <button class="btn btn-primary" type="submit">Search</button>

        <a asp-page="/ReadPage/Index" class="btn btn-secondary">Reset</a>
    </div>
</form>

<div class="row g-4">

    <div class="col-lg-4">
        <div class="position-sticky" style="top: 20px;">

            <h4 class="fw-bold mb-3">Add New Records</h4>

            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold text-primary">New Client</h6>

                    <form method="post" asp-page="/CreatePage/Index">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TargetTable" value="Client" />

                        <input type="text" name="FirstName" class="form-control mb-2" placeholder="First Name" required />
                        <input type="text" name="MiddleName" class="form-control mb-2" placeholder="Middle Name" />
                        <input type="text" name="LastName" class="form-control mb-2" placeholder="Last Name" required />
                        <input type="text" name="ContactInfo" class="form-control mb-2" placeholder="Contact Number" />

                        <button type="submit" class="btn btn-primary w-100">Create Client</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold text-info">New Counselor</h6>

                    <form method="post" asp-page="/CreatePage/Index">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TargetTable" value="Counselor" />

                        <input type="text" name="FirstName" class="form-control mb-2" placeholder="First Name" required />
                        <input type="text" name="MiddleName" class="form-control mb-2" placeholder="Middle Name" />
                        <input type="text" name="LastName" class="form-control mb-2" placeholder="Last Name" required />
                        <input type="text" name="Specialty" class="form-control mb-2" placeholder="Specialty" />

                        <button type="submit" class="btn btn-info text-white w-100">Create Counselor</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold text-warning">Schedule Session</h6>

                    <form method="post" asp-page="/CreatePage/Index">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TargetTable" value="Session" />

                        <label class="small text-muted">Session Date</label>
                        <input type="datetime-local"
                               name="SessionDate"
                               class="form-control mb-2"
                               required
                               min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />

                        <select name="ClientID" class="form-select mb-2" required>
                            <option value="">Select Client</option>
                            @foreach (var client in Model.ClientList)
                            {
                                <option value="@client.ClientID">@client.FirstName</option>
                            }
                        </select>

                        <select name="CounselorID" class="form-select mb-2" required>
                            <option value="">Select Counselor</option>
                            @foreach (var co in Model.CounselorList)
                            {
                                <option value="@co.CounselorID">@co.FirstName</option>
                            }
                        </select>

                        <button type="submit" class="btn btn-warning w-100">Book Session</button>
                    </form>
                </div>
            </div>

        </div>
    </div>

    <div class="col-lg-8">

        <ul class="nav nav-pills mb-3">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#clients">Clients</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="pill" data-bs-target="#counselors">Counselors</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="pill" data-bs-target="#sessions">Sessions</button>
            </li>
        </ul>

        <div class="tab-content bg-white shadow-sm rounded p-3">

            <div class="tab-pane fade show active" id="clients">
                <table class="table table-hover table-sm align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Contact</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.ClientList)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@c.FirstName</div>
                                    <small class="text-muted">ID: @c.ClientID</small>
                                </td>
                                <td>@c.ContactInfo</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="tab-pane fade" id="counselors">
                <table class="table table-hover table-sm align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Counselor</th>
                            <th>Specialty</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var co in Model.CounselorList)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@co.FirstName</div>
                                    <small class="text-muted">ID: @co.CounselorID</small>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        @co.Specialty
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="tab-pane fade" id="sessions">
                <table class="table table-hover table-sm align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.SessionList)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@s.SessionDate.ToString("MMM dd, yyyy")</div>
                                    <small class="text-muted">@s.SessionDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <div>Client: <b>@s.ClientFullName</b></div>
                                    <div>Counselor: <b>@s.CounselorFullName</b></div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>