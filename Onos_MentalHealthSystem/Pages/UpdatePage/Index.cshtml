@page
@model MentalHealthSystem_Onos_J.Pages.UpdatePage.IndexModel
@{
    ViewData["Title"] = "Update " + Model.Target;
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h4 class="fw-bold text-primary mb-4">Edit @Model.Target</h4>
                    <hr class="mb-4 text-muted opacity-25">

                    <form method="post">

                        <input type="hidden" asp-for="Target" />
                        <input type="hidden" asp-for="Id" />

                        @if (Model.HasSession && (Model.Target == "Client" || Model.Target == "Counselor"))
                        {
                            <div class="alert alert-warning text-center">
                                ⚠ This @Model.Target cannot be edited because it has a scheduled session.
                            </div>

                            <a asp-page="/ReadPage/Index" class="btn btn-secondary w-100">
                                Back
                            </a>
                        }
                        else
                        {
                            if (Model.Target == "Client")
                            {
                                <div class="mb-3">
                                    <input asp-for="CurrentClient.FirstName" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <input asp-for="CurrentClient.LastName" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <input asp-for="CurrentClient.ContactInfo" class="form-control" />
                                </div>
                            }
                            else if (Model.Target == "Counselor")
                            {
                                <div class="mb-3">
                                    <input asp-for="CurrentCounselor.FirstName" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <input asp-for="CurrentCounselor.LastName" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <input asp-for="CurrentCounselor.Specialty" class="form-control" />
                                </div>
                            }
                            else if (Model.Target == "Session")
                            {
                                <div class="mb-3">
                                    <input asp-for="CurrentSession.SessionDate" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <select asp-for="CurrentSession.ClientID" class="form-select">
                                        @foreach (var c in Model.ClientOpts)
                                        {
                                            <option value="@c.ClientID">@c.FirstName</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <select asp-for="CurrentSession.CounselorID" class="form-select">
                                        @foreach (var co in Model.CounselorOpts)
                                        {
                                            <option value="@co.CounselorID">@co.FirstName</option>
                                        }
                                    </select>
                                </div>
                            }
                            <button type="submit" class="btn btn-primary w-100">
                                Save Changes
                            </button>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
